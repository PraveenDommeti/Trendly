{
  "mcpServers": {
    "trendly-ai-catalog-matcher": {
      "command": "node",
      "args": ["dist/mcp-server.js"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_ANON_KEY": "${eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imh6em12eXlwZ3V5em1vdGNjdmZzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTA2NjU1MjcsImV4cCI6MjA2NjI0MTUyN30.HOpsfc1Mq3XTWi190EkvVIKxaP79NwY9163CLNcNXhQ}",
        "TRENDLY_API_KEY": "${TRENDLY_API_KEY}"
      }
    }
  },
  "server": {
    "name": "trendly-ai-catalog-matcher",
    "version": "1.0.0",
    "description": "AI-Powered Smart Tagging & Catalog Matching MCP Server for Trendly Fashion Platform",
    "capabilities": {
      "tools": [
        {
          "name": "analyze_outfit_image",
          "description": "Analyze an outfit photo using AI to detect clothing items, accessories, and style context",
          "inputSchema": {
            "type": "object",
            "properties": {
              "image_data": {
                "type": "string",
                "description": "Base64 encoded image data or image URL",
                "format": "data-url"
              },
              "user_id": {
                "type": "string",
                "description": "Optional user ID for personalized analysis based on style profile"
              },
              "analysis_context": {
                "type": "object",
                "properties": {
                  "occasion": {
                    "type": "string",
                    "enum": ["casual", "formal", "party", "business", "athletic", "evening", "weekend", "vacation"],
                    "description": "Optional context about the outfit occasion"
                  },
                  "season": {
                    "type": "string",
                    "enum": ["spring", "summer", "fall", "winter", "all-season"],
                    "description": "Optional seasonal context"
                  },
                  "style_preference": {
                    "type": "string",
                    "description": "Optional user's style preference (e.g., 'minimalist', 'bohemian', 'streetwear')"
                  }
                }
              }
            },
            "required": ["image_data"]
          }
        },
        {
          "name": "find_product_matches",
          "description": "Find matching products from Trendly's catalog based on AI analysis results",
          "inputSchema": {
            "type": "object",
            "properties": {
              "analysis_result": {
                "type": "object",
                "description": "Result from analyze_outfit_image tool",
                "properties": {
                  "detected_items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "category": {
                          "type": "string",
                          "enum": ["tops", "bottoms", "footwear", "accessories", "outerwear"]
                        },
                        "description": {
                          "type": "string"
                        },
                        "color": {
                          "type": "string"
                        },
                        "style": {
                          "type": "string"
                        },
                        "confidence": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 1
                        },
                        "attributes": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "outfit_context": {
                    "type": "object",
                    "properties": {
                      "occasion": {
                        "type": "string"
                      },
                      "style": {
                        "type": "string"
                      },
                      "season": {
                        "type": "string"
                      }
                    }
                  },
                  "model_context": {
                    "type": "object",
                    "properties": {
                      "body_type": {
                        "type": "string"
                      },
                      "skin_tone": {
                        "type": "string"
                      },
                      "style_preference": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "match_preferences": {
                "type": "object",
                "properties": {
                  "max_results": {
                    "type": "number",
                    "default": 20,
                    "description": "Maximum number of product matches to return"
                  },
                  "min_confidence": {
                    "type": "number",
                    "default": 0.3,
                    "minimum": 0,
                    "maximum": 1,
                    "description": "Minimum confidence threshold for matches"
                  },
                  "include_external": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether to include external product recommendations"
                  },
                  "price_range": {
                    "type": "object",
                    "properties": {
                      "min": {
                        "type": "number"
                      },
                      "max": {
                        "type": "number"
                      }
                    }
                  },
                  "categories": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["tops", "bottoms", "footwear", "accessories", "outerwear"]
                    },
                    "description": "Filter by specific categories"
                  }
                }
              }
            },
            "required": ["analysis_result"]
          }
        },
        {
          "name": "get_user_style_profile",
          "description": "Retrieve user's style profile and preferences for personalized recommendations",
          "inputSchema": {
            "type": "object",
            "properties": {
              "user_id": {
                "type": "string",
                "description": "User ID to retrieve style profile for"
              }
            },
            "required": ["user_id"]
          }
        },
        {
          "name": "update_style_profile",
          "description": "Update user's style profile based on outfit analysis and preferences",
          "inputSchema": {
            "type": "object",
            "properties": {
              "user_id": {
                "type": "string",
                "description": "User ID to update style profile for"
              },
              "style_preferences": {
                "type": "object",
                "properties": {
                  "preferred_styles": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "preferred_colors": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "body_type": {
                    "type": "string"
                  },
                  "skin_tone": {
                    "type": "string"
                  },
                  "size_preferences": {
                    "type": "object",
                    "properties": {
                      "tops": {
                        "type": "string"
                      },
                      "bottoms": {
                        "type": "string"
                      },
                      "footwear": {
                        "type": "string"
                      }
                    }
                  },
                  "price_range": {
                    "type": "object",
                    "properties": {
                      "min": {
                        "type": "number"
                      },
                      "max": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            },
            "required": ["user_id", "style_preferences"]
          }
        },
        {
          "name": "create_outfit_post",
          "description": "Create a new outfit post with AI-generated tags and product recommendations",
          "inputSchema": {
            "type": "object",
            "properties": {
              "user_id": {
                "type": "string",
                "description": "User ID creating the post"
              },
              "image_url": {
                "type": "string",
                "description": "URL of the uploaded outfit image"
              },
              "description": {
                "type": "string",
                "description": "Optional post description"
              },
              "analysis_result": {
                "type": "object",
                "description": "Result from analyze_outfit_image tool"
              },
              "tagged_products": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "product_id": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number"
                    },
                    "match_reason": {
                      "type": "string"
                    }
                  }
                }
              },
              "ai_generated_tags": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "AI-generated style tags for the outfit"
              }
            },
            "required": ["user_id", "image_url", "analysis_result"]
          }
        },
        {
          "name": "get_trending_products",
          "description": "Get trending products based on current fashion trends and user preferences",
          "inputSchema": {
            "type": "object",
            "properties": {
              "user_id": {
                "type": "string",
                "description": "Optional user ID for personalized trending products"
              },
              "category": {
                "type": "string",
                "enum": ["tops", "bottoms", "footwear", "accessories", "outerwear"],
                "description": "Optional category filter"
              },
              "limit": {
                "type": "number",
                "default": 10,
                "description": "Number of trending products to return"
              }
            }
          }
        },
        {
          "name": "generate_style_recommendations",
          "description": "Generate personalized style recommendations based on user profile and outfit analysis",
          "inputSchema": {
            "type": "object",
            "properties": {
              "user_id": {
                "type": "string",
                "description": "User ID for personalized recommendations"
              },
              "outfit_analysis": {
                "type": "object",
                "description": "Optional outfit analysis to base recommendations on"
              },
              "recommendation_type": {
                "type": "string",
                "enum": ["complete_outfit", "accessories", "alternatives", "seasonal"],
                "default": "complete_outfit"
              },
              "occasion": {
                "type": "string",
                "description": "Target occasion for recommendations"
              }
            },
            "required": ["user_id"]
          }
        }
      ]
    }
  },
  "responseSchemas": {
    "analyze_outfit_image": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean"
        },
        "analysis": {
          "type": "object",
          "properties": {
            "detected_items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "category": {
                    "type": "string",
                    "enum": ["tops", "bottoms", "footwear", "accessories", "outerwear"]
                  },
                  "description": {
                    "type": "string"
                  },
                  "color": {
                    "type": "string"
                  },
                  "style": {
                    "type": "string"
                  },
                  "confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "attributes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "bounding_box": {
                    "type": "object",
                    "properties": {
                      "x": {
                        "type": "number"
                      },
                      "y": {
                        "type": "number"
                      },
                      "width": {
                        "type": "number"
                      },
                      "height": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            },
            "outfit_context": {
              "type": "object",
              "properties": {
                "occasion": {
                  "type": "string"
                },
                "style": {
                  "type": "string"
                },
                "season": {
                  "type": "string"
                },
                "confidence": {
                  "type": "number"
                }
              }
            },
            "model_context": {
              "type": "object",
              "properties": {
                "body_type": {
                  "type": "string"
                },
                "skin_tone": {
                  "type": "string"
                },
                "style_preference": {
                  "type": "string"
                }
              }
            },
            "ai_generated_tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "processing_time": {
          "type": "number",
          "description": "Time taken for analysis in milliseconds"
        }
      }
    },
    "find_product_matches": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean"
        },
        "matches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "product": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "price": {
                    "type": "number"
                  },
                  "brand": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string"
                  },
                  "image_url": {
                    "type": "string"
                  },
                  "is_internal": {
                    "type": "boolean"
                  },
                  "affiliate_link": {
                    "type": "string"
                  },
                  "stock_quantity": {
                    "type": "number"
                  }
                }
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "match_reason": {
                "type": "string"
              },
              "similarity": {
                "type": "object",
                "properties": {
                  "category": {
                    "type": "number"
                  },
                  "color": {
                    "type": "number"
                  },
                  "style": {
                    "type": "number"
                  },
                  "overall": {
                    "type": "number"
                  }
                }
              },
              "personalization_score": {
                "type": "number",
                "description": "Score based on user's style profile compatibility"
              }
            }
          }
        },
        "total_matches": {
          "type": "number"
        },
        "match_summary": {
          "type": "object",
          "properties": {
            "exact_matches": {
              "type": "number"
            },
            "similar_matches": {
              "type": "number"
            },
            "recommended_alternatives": {
              "type": "number"
            }
          }
        }
      }
    },
    "get_user_style_profile": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean"
        },
        "profile": {
          "type": "object",
          "properties": {
            "user_id": {
              "type": "string"
            },
            "preferred_styles": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "preferred_colors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "body_type": {
              "type": "string"
            },
            "skin_tone": {
              "type": "string"
            },
            "size_preferences": {
              "type": "object"
            },
            "price_range": {
              "type": "object",
              "properties": {
                "min": {
                  "type": "number"
                },
                "max": {
                  "type": "number"
                }
              }
            },
            "favorite_brands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "avoided_styles": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "create_outfit_post": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean"
        },
        "post": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "user_id": {
              "type": "string"
            },
            "image_url": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "ai_generated_tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "tagged_products": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "created_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "engagement_prediction": {
          "type": "object",
          "properties": {
            "predicted_likes": {
              "type": "number"
            },
            "predicted_comments": {
              "type": "number"
            },
            "predicted_shares": {
              "type": "number"
            },
            "confidence": {
              "type": "number"
            }
          }
        }
      }
    }
  },
  "errorSchemas": {
    "common_errors": {
      "type": "object",
      "properties": {
        "error": {
          "type": "string",
          "enum": [
            "INVALID_IMAGE_FORMAT",
            "IMAGE_TOO_LARGE",
            "AI_ANALYSIS_FAILED",
            "NO_PRODUCTS_FOUND",
            "USER_NOT_FOUND",
            "INSUFFICIENT_PERMISSIONS",
            "RATE_LIMIT_EXCEEDED",
            "INTERNAL_SERVER_ERROR"
          ]
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object"
        },
        "retry_after": {
          "type": "number",
          "description": "Seconds to wait before retrying (for rate limit errors)"
        }
      }
    }
  },
  "configuration": {
    "ai_model": {
      "provider": "google",
      "model": "gemini-1.5-flash",
      "max_tokens": 4096,
      "temperature": 0.3
    },
    "image_processing": {
      "max_file_size": "10MB",
      "supported_formats": ["jpg", "jpeg", "png", "webp"],
      "max_dimensions": {
        "width": 4096,
        "height": 4096
      }
    },
    "matching": {
      "min_confidence_threshold": 0.3,
      "max_results_per_category": 10,
      "similarity_weights": {
        "category": 0.4,
        "color": 0.3,
        "style": 0.3
      }
    },
    "rate_limits": {
      "requests_per_minute": 60,
      "requests_per_hour": 1000,
      "concurrent_analyses": 5
    }
  },
  "webhooks": {
    "outfit_analysis_complete": {
      "url": "/webhooks/analysis-complete",
      "method": "POST",
      "description": "Triggered when outfit analysis is completed"
    },
    "product_match_found": {
      "url": "/webhooks/product-match",
      "method": "POST",
      "description": "Triggered when high-confidence product matches are found"
    }
  },
  "monitoring": {
    "metrics": [
      "analysis_accuracy",
      "matching_precision",
      "user_satisfaction",
      "processing_time",
      "error_rate"
    ],
    "logging": {
      "level": "info",
      "format": "json"
    }
  }
} 